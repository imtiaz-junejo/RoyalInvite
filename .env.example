# =============================================================================
# Eternally Yours — Environment Variables
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
# =============================================================================

# -----------------------------------------------------------------------------
# Database (required)
# MySQL 8.x connection string used by Prisma
# -----------------------------------------------------------------------------
DATABASE_URL="mysql://eternally_yours:your_password@127.0.0.1:3306/eternally_yours"

# -----------------------------------------------------------------------------
# Authentication (required)
# Generate secrets with: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
MOBILE_SESSION_SECRET=""

# -----------------------------------------------------------------------------
# Application URLs
# APP_URL — canonical site URL for SEO, share links, and metadata
# NEXT_PUBLIC_SITE_URL — public base URL exposed to the browser / mobile API
# VERCEL_URL — set automatically on Vercel (do not set locally)
# -----------------------------------------------------------------------------
APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# WhatsApp gateway (optional — required for WhatsApp sender / RSVP updates)
# Run a compatible WhatsApp gateway service separately (default port 3020)
# -----------------------------------------------------------------------------
WHATSAPP_GATEWAY_URL="http://127.0.0.1:3020"
WHATSAPP_GATEWAY_INTERNAL_TOKEN=""
WHATSAPP_SESSION_ID="eternally-yours-main"

# Legacy alias accepted by the gateway client (use WHATSAPP_GATEWAY_INTERNAL_TOKEN)
# INTERNAL_TOKEN=""

# -----------------------------------------------------------------------------
# Runtime (optional — usually set by the host)
# -----------------------------------------------------------------------------
# NODE_ENV=development
